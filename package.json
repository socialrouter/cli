{
  "name": "@socialrouter/cli",
  "version": "0.1.0",
  "description": "Command-line interface for the SocialRouter API",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "socialrouter": "dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "socialrouter",
    "cli",
    "social-media",
    "scraping",
    "linkedin",
    "instagram",
    "twitter",
    "x",
    "reddit"
  ],
  "author": "SocialRouter",
  "license": "MIT",
  "homepage": "https://www.socialrouter.io",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "chalk": "^5.6.2",
    "ora": "^9.3.0",
    "@socialrouter/sdk": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
